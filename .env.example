# ──────────────────────────────────────────────
# OnePay Checkout Configuration (server .env only — never in frontend)
# API base URL is fixed in config/onepay.php; do not expose it to clients.
# ──────────────────────────────────────────────
ONEPAY_APP_ID=your-app-id-here
ONEPAY_APP_TOKEN=your-app-token-here
ONEPAY_HASH_SALT=your-hash-salt-here
ONEPAY_CURRENCY=LKR
ONEPAY_TIMEOUT=30
ONEPAY_RETRY_TIMES=3
ONEPAY_RETRY_SLEEP_MS=500
