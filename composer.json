{
    "name": "onepay/laravel-checkout",
    "description": "Laravel integration for the OnePay Checkout Link API",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "onepay", "checkout", "payment", "sri-lanka"],
    "authors": [
        {
            "name": "Salitha",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "OnePay\\Checkout\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OnePay\\Checkout\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "OnePay\\Checkout\\OnePayServiceProvider"
            ],
            "aliases": {
                "OnePay": "OnePay\\Checkout\\Facades\\OnePay"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "test": "@php vendor/bin/phpunit -c phpunit.xml.dist"
    }
}
